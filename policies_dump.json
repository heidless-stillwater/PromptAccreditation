    "id": "online-safety-act",
    "slug": "online-safety-act",
    "name": "Online Safety Act 2023",
    "category": "safety",
    "regulatoryBody": "Ofcom",
    "maxPenalty": "£18M or 10% of global annual turnover",
    "legislativeUrl": "https://www.legislation.gov.uk/ukpga/2023/50",
    "status": "red",
