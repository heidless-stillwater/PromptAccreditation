    "id": "site-security",
    "slug": "site-security",
    "name": "Site Security Policy",
    "category": "security",
    "regulatoryBody": "NCSC / Internal",
    "maxPenalty": "Breach liability, regulatory notification obligations",
    "intensity": "soft",
    "targetApps": [
      "promptresources",
